APP_NAME=Linux Command Center
APP_ENV=development
APP_DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

DATABASE_URL=postgresql+psycopg://command_center:command_center@postgres:5432/command_center
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:3000

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_DISPLAY_NAME=Administrator

SESSION_COOKIE_NAME=lcc_session
SESSION_EXPIRE_HOURS=8
SESSION_COOKIE_SECURE=false

POSTGRES_DB=command_center
POSTGRES_USER=command_center
POSTGRES_PASSWORD=command_center

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
